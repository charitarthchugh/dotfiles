[filter "lfs"]
clean = git-lfs clean -- %f
smudge = git-lfs smudge -- %f
process = git-lfs filter-process
required = true
[user]
name = charitarthchugh
email = 37895518+charitarthchugh@users.noreply.github.com
[core]
autocrlf = input
editor = nvim
[hub]
protocol = https
[pull]
rebase = false
[push]
autoSetupRemote = true
[init]
defaultBranch = main
[credential]
helper = store
[maintenance]
repo = ~/dotfiles
repo = ~/.local/share/fonts/NerdFonts
repo = ~/.local/share/fonts/Google
[pager]
diff = delta
log = delta
reflog = delta
show = delta
[delta]
navigate = true
[interactive]
diffFilter = delta --color-only
[ghq]
root = ~/Dev/ghq/ 
[safe]
	directory = /opt/flutter
[credential "https://github.com"]
	helper = 
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !gh auth git-credential

